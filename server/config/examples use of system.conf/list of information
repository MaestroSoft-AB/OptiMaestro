const char *keys[] = { "upstream.servers" };

char servers_str[256];
char *values[] = { servers_str };

config_get_value(
    "server/config/system.conf",
    keys,
    values,
    sizeof(servers_str),
    1 //number of keys(buffers to store the results)
);

char *token = strtok(servers_str, ",");
while (token) {
    register_upstream(token);
    token = strtok(NULL, ",");
}

