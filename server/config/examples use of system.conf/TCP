const char *keys[] = {
    "tcp.host",
    "tcp.port",
    "tcp.backlog"
};

char host[64];
char port_str[16];
char backlog_str[16]; // 

char *values[] = {
    host,
    port_str,
    backlog_str
};

config_get_value(
    "server/config/system.conf",
    keys,
    values,
    sizeof(host),
    3 //number of keys(buffers to store the results)
);

int port = atoi(port_str);
int backlog = atoi(backlog_str); //atoi to convert string to integer (start_tcp_server (host, port, backlog) needs an integer)

start_tcp_server(host, port, backlog);
